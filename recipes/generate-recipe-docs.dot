// Generates DOT flowchart diagrams and PNGs for all recipe YAML files in a repository.
digraph generate_recipe_docs {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Recipe Documentation Generator\nCreates accessible flowchart diagrams for each recipe file"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="862100d7700d0ecc9789af928598fbd170f601b3e3140431247c35b09a018edf"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done", shape=oval, fillcolor="#e0e0e0"]

    step_discover_and_generate [label="Discover Recipes\n\"Find YAMLs and generate DOT skeletons\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'PYEOF' import json import sys from pathlib import Path  repo_path = Path('{{repo_path}}'"]
    step_enhance_labels [label="Enhance Labels\n\"Rewrite for clarity\"\n(for each)", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]
    step_write_and_render [label="Write and Render\n\"Save DOT files and generate PNGs\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'PYEOF' import json import subprocess import re from pathlib import Path  _discovery_raw "]
    step_summary [label="Summarize Results\n\"Report what was generated\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'PYEOF' import json  _discovery_raw = r'''{{discovery}}''' _write_raw = r'''{{write_resul"]

    start -> step_discover_and_generate
    step_discover_and_generate -> step_enhance_labels
    step_enhance_labels -> step_write_and_render
    step_write_and_render -> step_summary
    step_summary -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_bash [label="Script Step", shape=box, fillcolor="#bbdefb"]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_bash -> leg_agent -> leg_start [style=invis]
    }
}