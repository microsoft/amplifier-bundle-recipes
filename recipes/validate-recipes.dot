// Validates recipe YAML files for correctness, best practices, and semantic consistency.
digraph validate_recipes {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Recipe Validation Pipeline\nScans recipe files for structural, semantic, and best-practice issues"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="fc6c4f285cd42e2c53fc6bd2de45577e0d698126656f22d123ee60fa9b618b4e"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done", shape=oval, fillcolor="#e0e0e0"]

    step_environment_check [label="Check Environment\n\"Are the required tools installed?\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json import sys from pathlib import Path  results = {     'phase': 'environm"]
    step_recipe_discovery [label="Discover Recipes\n\"Scan folders for YAML recipe files\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json from pathlib import Path  def _process_yaml_file(yaml_path, base, resul"]
    step_structural_validation [label="Validate Structure\n\"Are the YAML files well-formed?\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json import re from pathlib import Path  _env_check_raw = r'''{{env_check}}'"]
    step_best_practices_check [label="Check Best Practices\n\"Naming, timeouts, error handling?\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json import re from pathlib import Path  _recipe_discovery_raw = r'''{{recip"]
    step_semantic_validation [label="Validate Semantics\n\"Do references and variables resolve?\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json from fnmatch import fnmatch from pathlib import Path  _recipe_discovery"]
    step_quality_classification [label="Classify Quality\n\"Assign a grade to each recipe\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json  _structural_results_raw = r'''{{structural_results}}''' _practice_resu"]
    cond_step_quick_approval [label="All clean?", shape=diamond, fillcolor="#fff9c4"]
    step_quick_approval [label="Quick Approval\n\"No issues found — all pass\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json  _quality_classification_raw = r'''{{quality_classification}}''' qualit"]
    cond_step_synthesize_report [label="Issues found?", shape=diamond, fillcolor="#fff9c4"]
    step_synthesize_report [label="Compile Report\n\"Combine all findings into one summary\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]
    step_dot_freshness_check [label="Check Diagram Freshness\n\"Are the flowcharts up to date?\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json import re from pathlib import Path  _recipe_discovery_raw = r'''{{recip"]

    start -> step_environment_check
    step_environment_check -> step_recipe_discovery
    step_recipe_discovery -> step_structural_validation
    step_recipe_discovery -> step_best_practices_check
    step_recipe_discovery -> step_semantic_validation
    step_structural_validation -> step_quality_classification
    step_best_practices_check -> step_quality_classification
    step_semantic_validation -> step_quality_classification
    step_quality_classification -> cond_step_quick_approval
    cond_step_quick_approval -> step_quick_approval [label="quality_classification.re"]
    step_quality_classification -> cond_step_synthesize_report
    cond_step_synthesize_report -> step_synthesize_report [label="quality_classification.re"]
    step_recipe_discovery -> step_dot_freshness_check
    cond_step_quick_approval -> step_dot_freshness_check [label="skip", style=dashed]
    cond_step_synthesize_report -> step_dot_freshness_check [label="skip", style=dashed]
    step_dot_freshness_check -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_bash [label="Script Step", shape=box, fillcolor="#bbdefb"]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_cond [label="Condition", shape=diamond, fillcolor="#fff9c4"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_bash -> leg_agent -> leg_cond -> leg_start [style=invis]
    }
}