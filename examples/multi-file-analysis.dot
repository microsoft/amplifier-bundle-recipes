// Analyzes multiple files in parallel with per-file insights and a consolidated summary.
digraph multi_file_analysis {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Parallel File Analysis\nAnalyzes multiple files concurrently, then produces a consolidated summary"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="4130c5c30664ce5fe45ecd6e411c15ebb37501cadda1f1070ba4839442fef061"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done", shape=oval, fillcolor="#e0e0e0"]

    step_analyze_each_file [label="Analyze Each File\n\"Assess quality and issues\"\n(for each)", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]
    step_create_summary [label="Create Summary\n\"Consolidate findings across all files\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]

    start -> step_analyze_each_file
    step_analyze_each_file -> step_create_summary
    step_create_summary -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_agent -> leg_start [style=invis]
    }
}