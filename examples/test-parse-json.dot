// Tests parse_json functionality — prose preservation vs. JSON extraction.
digraph test_parse_json {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="JSON Parsing Test\nVerifies that prose and structured JSON outputs are handled correctly"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="37668b278824b7c906afe93b0a3d18a50c58ee7d67e5e9b0a8bc52fd59ef0b99"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done", shape=oval, fillcolor="#e0e0e0"]

    step_prose_step [label="Generate Prose Output\n\"Natural language response\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]
    step_json_step [label="Extract JSON Output\n\"Structured data extraction\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]
    step_verify [label="Verify Both Outputs\n\"Did each format work correctly?\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]

    start -> step_prose_step
    step_prose_step -> step_json_step
    step_json_step -> step_verify
    step_verify -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_agent -> leg_start [style=invis]
    }
}