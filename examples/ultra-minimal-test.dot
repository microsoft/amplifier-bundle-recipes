// Ultra-minimal test recipe — one step, one greeting, verifies basic execution.
digraph ultra_minimal_test {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Minimal Recipe Test\nThe simplest possible recipe — a single-step greeting"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="17b65ddc6dec525771450e9dbb45f508d8705fe2277a0feef5d599c90665411e"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done", shape=oval, fillcolor="#e0e0e0"]

    step_hello [label="Say Hello\n\"A simple greeting\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="recipes:recipe-author"]

    start -> step_hello
    step_hello -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_agent -> leg_start [style=invis]
    }
}