// Multi-perspective security analysis covering vulnerabilities, configurations, and dependencies.
digraph security_audit_comprehensive {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Security Audit Pipeline\nScans for vulnerabilities, reviews configurations, and audits dependencies"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="cc0eb9cd06540497d99ac74cf4178a4dcb020bacb7577712deb89c5c3c5db1da"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done", shape=oval, fillcolor="#e0e0e0"]

    step_vulnerability_scan [label="Scan for Vulnerabilities\n\"SQL injection, XSS, auth issues\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:security-guardian"]
    step_configuration_review [label="Review Configuration\n\"Hardcoded secrets, unsafe defaults\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:security-guardian"]
    step_dependency_audit [label="Audit Dependencies\n\"Check versions and known CVEs\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:security-guardian"]
    step_synthesize_findings [label="Compile Remediation Plan\n\"Prioritize and plan fixes\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]

    start -> step_vulnerability_scan
    step_vulnerability_scan -> step_configuration_review
    step_configuration_review -> step_dependency_audit
    step_dependency_audit -> step_synthesize_findings
    step_synthesize_findings -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_agent -> leg_start [style=invis]
    }
}