// Analyzes development work and generates a polished, human-friendly feature announcement.
digraph feature_announcement {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Feature Announcement Generator\nAnalyzes recent changes and writes a team-ready announcement"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="f08744619118655e5746b371b01c309037aa88f382e36ee8cf929a91cc2c71ee"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done", shape=oval, fillcolor="#e0e0e0"]

    step_analyze_changes [label="Analyze Changes\n\"What was built or fixed?\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]
    step_generate_announcement [label="Write Announcement\n\"Draft a team-friendly post\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]
    step_save_announcement [label="Save to File\n\"Ready to share\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]

    start -> step_analyze_changes
    step_analyze_changes -> step_generate_announcement
    step_generate_announcement -> step_save_announcement
    step_save_announcement -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_agent -> leg_start [style=invis]
    }
}