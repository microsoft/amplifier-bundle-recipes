// Verifies session work using a different AI provider to catch blind spots.
digraph session_verify {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Cross-Provider Session Verification\nUses a different AI provider to independently verify work from a prior session"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="c566b30b3286376d7427820e0e2b7dc81853b50aa2740b186814e4459aedd48c"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done", shape=oval, fillcolor="#e0e0e0"]

    step_extract_session_context [label="Extract Session Context\n\"Intent, claims, and actual results\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:session-analyst"]
    step_verification_review [label="Run Verification Audit\n\"Does the work match the intent?\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]

    start -> step_extract_session_context
    step_extract_session_context -> step_verification_review
    step_verification_review -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_agent -> leg_start [style=invis]
    }
}