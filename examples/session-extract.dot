// Extracts provider, model, and summary from a session to guide verification strategy.
digraph session_extract {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Session Metadata Extraction\nQuickly identifies the AI provider and model used in a past session"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="675ab65f10cdc95c16d07836725ae3e24cd86109338694becd85acdecdc1cafa"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done", shape=oval, fillcolor="#e0e0e0"]

    step_quick_extract [label="Extract Session Metadata\n\"Provider, model, and summary\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:session-analyst"]

    start -> step_quick_extract
    step_quick_extract -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_agent -> leg_start [style=invis]
    }
}